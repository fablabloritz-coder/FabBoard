# FabBoard Configuration
FABBOARD_PORT=5580
FABBOARD_SECRET=change-me-in-production

# Fabtrack API (si en Docker, utiliser http://fabtrack:5555)
FABTRACK_URL=http://localhost:5555

# Repetier Server
REPETIER_URL=http://192.168.1.100:3344
REPETIER_APIKEY=

# Nextcloud CalDAV
NEXTCLOUD_CALDAV_URL=https://votre-nextcloud.com/remote.php/dav
NEXTCLOUD_USER=fablab
NEXTCLOUD_PASS=motdepasse
NEXTCLOUD_CALENDAR_NAME=fablab

# PrusaLink (optionnel, séparer par virgule si plusieurs)
PRUSALINK_URLS=
PRUSALINK_APIKEYS=

# Paramètres dashboard
REFRESH_INTERVAL_SEC=30
FABLAB_NAME=Loritz'Lab
